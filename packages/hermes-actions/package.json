{
  "name": "@paperclipai/hermes-actions",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "HermesAgent V1 action layer: typed registry, sudo-wrapper executor, hash-chained audit journal, and failure handler. Bridges a validated HermesIntent to the privileged shell wrappers installed by LIF-237.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./registry": "./src/registry.ts",
    "./executor": "./src/executor.ts",
    "./journal": "./src/journal.ts",
    "./notify": "./src/notify.ts",
    "./failure-handler": "./src/failure-handler.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  }
}
